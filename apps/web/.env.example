# Copy to .env.local and fill in real values.
# For local iteration without every third-party key, you may set SKIP_ENV_VALIDATION=1 (tests and some scripts only; not for production).

NODE_ENV=development

SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=246VxdVvQkKDk51fxbAYaszJHsqoRQd8vdqbBy7LKjgx
# JSON array of 64 bytes (same keypair as EXPECTED_RELAYER in programs/blinkremit/src/constants.rs for dev).
RELAYER_KEYPAIR=
# Must equal on-chain EXPECTED_RELAYER (see programs/blinkremit/src/constants.rs).
RELAYER_PUBKEY=D5bToaseZ3UvG1ZyEHh3x9SBo79VLfCunnsbQBtHW7c

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/blinkr
REDIS_URL=redis://localhost:6379

NEXT_PUBLIC_URL=http://localhost:3000
# Browser RPC for employer funding flow (Phantom). Defaults to devnet public RPC if unset.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional canonical site URL for metadata and Open Graph (falls back to NEXT_PUBLIC_URL).
NEXT_PUBLIC_SITE_URL=

JWT_SECRET=change-me-min-32-chars-for-jwt-hs256
SESSION_SECRET=change-me-min-32-chars-session

MESO_API_KEY=
MESO_WEBHOOK_SECRET=
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=

RESEND_API_KEY=
FROM_EMAIL=noreply@example.com

SENTRY_DSN=

HELIUS_WEBHOOK_AUTH_HEADER=
HELIUS_API_KEY=

# Devnet Circle USDC (matches on-chain EXPECTED_USDC_MINT in programs/blinkremit).
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
SQUADS_PROGRAM_ID=

CORS_ALLOWED_ORIGINS=http://localhost:3000

# Bearer secret for POST /api/cron/* routes
CRON_SECRET=

# --- Simulated bank cash-out (Stripe test mode + on-chain USDC sweep) ---
# Stripe secret key (sk_test_...) and webhook signing secret (whsec_...) from the Stripe dashboard.
# Local dev: webhooks often miss localhost; the Blink return URL still finalizes USDC via POST /api/offramp/stripe-complete.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# At least 32 characters; used to derive the contractor Solana wallet from email (server-side custodial demo).
CONTRACTOR_WALLET_DERIVATION_SECRET=change-me-min-32-chars-custodial-demo
# Optional: base58 pubkey that receives swept devnet USDC after Stripe setup completes. Defaults to RELAYER_PUBKEY.
OFFRAMP_TREASURY_WALLET=
