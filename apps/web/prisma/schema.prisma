generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BlinkStatus {
  PENDING
  OPENED
  CLAIMED
  OFFRAMPED
  EXPIRED
  REFUNDED
}

model Employer {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  email         String?
  blinks        Blink[]
  createdAt     DateTime @default(now())
}

/// Off-chain claim identity: `credentialId` is an opaque string hashed into on-chain `credential_hash` at claim time.
model Credential {
  id             String   @id @default(cuid())
  credentialId   String   @unique
  publicKey      Bytes
  walletAddress  String
  email          String
  counter        Int      @default(0)
  createdAt      DateTime @default(now())
  blinks         Blink[]

  @@index([email])
}

model Blink {
  id               String      @id @default(cuid())
  employerId       String
  contractorEmail  String
  amountUsdc       Decimal     @db.Decimal(18, 6)
  status           BlinkStatus @default(PENDING)
  escrowPDA        String?
  escrowTxSig      String?
  claimTxSig       String?
  walletAddress    String?
  credentialId     String?
  createdAt        DateTime    @default(now())
  expiresAt        DateTime
  claimedAt        DateTime?
  employer         Employer    @relation(fields: [employerId], references: [id])
  credential       Credential? @relation(fields: [credentialId], references: [id])
  offrampRequests  OfframpRequest[]

  @@index([status, expiresAt])
}

model OfframpRequest {
  id            String   @id @default(cuid())
  blinkId       String
  blink         Blink    @relation(fields: [blinkId], references: [id])
  provider      String
  status        String
  amountUsdc    Decimal  @db.Decimal(18, 6)
  fiatAmount    Decimal? @db.Decimal(18, 2)
  fiatCurrency  String?
  providerRef   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([blinkId])
}
